{
  "name": "resurrection",
  "version": "0.1.0",
  "description": "듀얼모니터 창 배치 복원 앱",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json -w\"",
    "start": "electron .",
    "build": "vite build && tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "rebuild": "electron-rebuild -f -w node-window-manager",
    "create-favicon": "node scripts/createFavicon.mjs"
  },
  "dependencies": {
    "electron-store": "^7.0.3",
    "node-window-manager": "^2.2.4"
  },
  "overrides": {
    "node-gyp": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
